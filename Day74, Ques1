// Given an array of candidate names where each name represents a vote cast for that candidate, determine the candidate who received the maximum number of votes. In case of a tie, return the lexicographically smallest candidate name.

#include <stdio.h>
#include <string.h>
#include <stdlib.h>

#define MAX 100
#define LEN 50

// Comparator for sorting strings
int compare(const void *a, const void *b) {
    return strcmp((char *)a, (char *)b);
}

int main() {
    int n;
    char votes[MAX][LEN];

    printf("Enter number of votes: ");
    scanf("%d", &n);

    printf("Enter candidate names:\n");
    for(int i = 0; i < n; i++) {
        scanf("%s", votes[i]);
    }

    // Step 1: Sort the array
    qsort(votes, n, sizeof(votes[0]), compare);

    // Step 2: Count votes
    int maxVotes = 1, count = 1;
    char winner[LEN];
    strcpy(winner, votes[0]);

    for(int i = 1; i < n; i++) {
        if(strcmp(votes[i], votes[i-1]) == 0) {
            count++;
        } else {
            if(count > maxVotes) {
                maxVotes = count;
                strcpy(winner, votes[i-1]);
            }
            count = 1;
        }
    }

    // Check last candidate
    if(count > maxVotes) {
        strcpy(winner, votes[n-1]);
    }

    // Output
    printf("Winner: %s\n", winner);
    printf("Votes: %d\n", maxVotes);

    return 0;
}
