// DO NOT redefine struct Node — LeetCode provides it:
// struct Node {
//     int val;
//     int numNeighbors;
//     struct Node** neighbors;
// };

struct Node* cloned[101];

struct Node* cloneNode(struct Node* node) {
    if (!node) return NULL;

    if (cloned[node->val]) return cloned[node->val];

    struct Node* copy = (struct Node*)malloc(sizeof(struct Node));
    copy->val = node->val;
    copy->numNeighbors = node->numNeighbors;
    copy->neighbors = (struct Node**)malloc(
        node->numNeighbors * sizeof(struct Node*)
    );

    cloned[node->val] = copy;  // register BEFORE recursing

    for (int i = 0; i < node->numNeighbors; i++) {
        copy->neighbors[i] = cloneNode(node->neighbors[i]);
    }

    return copy;
}

struct Node* cloneGraph(struct Node* node) {
    if (!node) return NULL;

    memset(cloned, 0, sizeof(cloned));

    return cloneNode(node);
}
