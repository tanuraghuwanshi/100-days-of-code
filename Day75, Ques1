// Given an array of integers containing both positive and negative values, find the length of the longest contiguous subarray whose sum is equal to zero.

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define TABLE_SIZE 10007

typedef struct Entry {
    int key;
    int value;
    struct Entry *next;
} Entry;

Entry *hashTable[TABLE_SIZE];

int hashFn(int key) {
    return ((key % TABLE_SIZE) + TABLE_SIZE) % TABLE_SIZE;
}

void insert(int key, int value) {
    int h = hashFn(key);
    Entry *e = malloc(sizeof(Entry));
    e->key = key;
    e->value = value;
    e->next = hashTable[h];
    hashTable[h] = e;
}

int search(int key, int *found_value) {
    int h = hashFn(key);
    Entry *e = hashTable[h];
    while (e) {
        if (e->key == key) {
            *found_value = e->value;
            return 1;
        }
        e = e->next;
    }
    return 0;
}

void clearTable() {
    for (int i = 0; i < TABLE_SIZE; i++) {
        Entry *e = hashTable[i];
        while (e) {
            Entry *tmp = e;
            e = e->next;
            free(tmp);
        }
        hashTable[i] = NULL;
    }
}

int longestZeroSumSubarray(int *arr, int n) {
    clearTable();

    // prefix_sum = 0 was "seen" at index -1
    insert(0, -1);

    int prefix_sum = 0;
    int max_len = 0;

    for (int i = 0; i < n; i++) {
        prefix_sum += arr[i];

        int prev_index;
        if (search(prefix_sum, &prev_index)) {
            int len = i - prev_index;
            if (len > max_len)
                max_len = len;
        } else {
            insert(prefix_sum, i);
        }
    }

    return max_len;
}

int main() {
    int arr[] = {3, -1, -3, 4, -2, 1, 6, -6};
    int n = sizeof(arr) / sizeof(arr[0]);

    printf("Array: ");
    for (int i = 0; i < n; i++) printf("%d ", arr[i]);
    printf("\n");

    int result = longestZeroSumSubarray(arr, n);
    printf("Longest zero-sum subarray length: %d\n", result);

    return 0;
}
